<!DOCTYPE html>
<html lang="tr" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Artroplus</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Artroplus Yönetim Paneli")" />

    <!--begin::Fonts (Metronic v9 - Inter)-->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <!--end::Fonts-->

    <!--begin::Global Stylesheets Bundle (Metronic v9.4.9 CDN)-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!--end::Global Stylesheets Bundle-->

    <style>
        :root {
            --kt-primary: #1b84ff;
            --kt-primary-hover: #056ee9;
            --kt-sidebar-width: 265px;
            --kt-sidebar-bg: #1e1e2d;
            --kt-sidebar-text: #9899ac;
            --kt-sidebar-text-hover: #ffffff;
            --kt-header-height: 65px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f8fa;
        }

        /* Sidebar */
        .sidebar {
            width: var(--kt-sidebar-width);
            min-height: 100vh;
            background: var(--kt-sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            z-index: 1000;
            overflow-y: auto;
            transition: all 0.3s ease;
        }

        .sidebar-logo {
            padding: 1.5rem 1.75rem;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-logo h4 {
            color: #ffffff;
            font-weight: 700;
            font-size: 1.2rem;
            margin: 0;
        }

        .sidebar-menu {
            padding: 1rem 0;
        }

        .sidebar-label {
            padding: 0.5rem 1.75rem;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
            letter-spacing: 1px;
        }

        .sidebar-item a {
            display: flex;
            align-items: center;
            padding: 0.65rem 1.75rem;
            color: var(--kt-sidebar-text);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            border-radius: 0;
            transition: all 0.2s ease;
        }

        .sidebar-item a:hover,
        .sidebar-item a.active {
            color: var(--kt-sidebar-text-hover);
            background-color: rgba(255,255,255,0.05);
        }

        .sidebar-item a i {
            margin-right: 0.75rem;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        /* Header */
        .main-header {
            position: fixed;
            top: 0;
            left: var(--kt-sidebar-width);
            right: 0;
            height: var(--kt-header-height);
            background: #ffffff;
            border-bottom: 1px solid #e4e6ef;
            z-index: 999;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            justify-content: space-between;
        }

        /* Content */
        .main-content {
            margin-left: var(--kt-sidebar-width);
            margin-top: var(--kt-header-height);
            padding: 2rem;
            min-height: calc(100vh - var(--kt-header-height));
        }

        /* Card */
        .card {
            border: 0;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
            border-radius: 0.75rem;
        }

        .card-header {
            background: transparent;
            border-bottom: 1px solid #e4e6ef;
            padding: 1.25rem 1.75rem;
            font-weight: 600;
        }

        /* Buttons */
        .btn-primary {
            background-color: var(--kt-primary);
            border-color: var(--kt-primary);
        }

        .btn-primary:hover {
            background-color: var(--kt-primary-hover);
            border-color: var(--kt-primary-hover);
        }

        /* Responsive */
        @@media (max-width: 991px) {
            .sidebar { transform: translateX(-100%); }
            .main-header { left: 0; }
            .main-content { margin-left: 0; }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <!--begin::Sidebar-->
    <div class="sidebar">
        <div class="sidebar-logo">
            <h4><i class="bi bi-grid-3x3-gap-fill me-2" style="color: var(--kt-primary);"></i>Artroplus</h4>
        </div>
        <div class="sidebar-menu">
            <div class="sidebar-label">Ana Menü</div>
            <div class="sidebar-item">
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i> Dashboard
                </a>
            </div>
            @RenderSection("SidebarMenu", required: false)
        </div>
    </div>
    <!--end::Sidebar-->

    <!--begin::Header-->
    <header class="main-header">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-light d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <span class="fw-semibold text-gray-700">@(ViewData["Title"] ?? "Dashboard")</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="dropdown">
                <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle fs-5"></i>
                    <span class="fw-semibold">@User.Identity?.Name</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>
    <!--end::Header-->

    <!--begin::Main Content-->
    <main class="main-content">
        @RenderBody()
    </main>
    <!--end::Main Content-->

    <!--begin::Scripts-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--end::Scripts-->

    @RenderSection("Scripts", required: false)
</body>
</html>
