@model List<Artroplus.Core.Entities.GuncellemeNotu>
@{
    ViewData["Title"] = "Dashboard";
}

<!--begin::Page Header-->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fs-4 fw-bold text-dark mb-1">Dashboard</h1>
        <p class="text-muted mb-0 fs-6">Hoş geldiniz, @User.Identity?.Name!</p>
    </div>
    <div class="text-muted small">
        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
    </div>
</div>
<!--end::Page Header-->

<!--begin::Stats Row-->
<div class="row g-4 mb-4">
    <!-- Stat cards removed for brevity in this snippet, let's keep them as they are good for the dashboard -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: rgba(27,132,255,0.1);">
                    <i class="bi bi-people-fill fs-4" style="color: #1b84ff;"></i>
                </div>
                <div>
                    <div class="fs-5 fw-bold text-dark">0</div>
                    <div class="text-muted small">Toplam Kullanıcı</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: rgba(23,198,83,0.1);">
                    <i class="bi bi-check-circle-fill fs-4" style="color: #17c653;"></i>
                </div>
                <div>
                    <div class="fs-5 fw-bold text-dark">0</div>
                    <div class="text-muted small">Aktif İşlem</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: rgba(255,161,0,0.1);">
                    <i class="bi bi-clock-fill fs-4" style="color: #ffa100;"></i>
                </div>
                <div>
                    <div class="fs-5 fw-bold text-dark">0</div>
                    <div class="text-muted small">Bekleyen</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: rgba(232,76,61,0.1);">
                    <i class="bi bi-exclamation-triangle-fill fs-4" style="color: #e84c3d;"></i>
                </div>
                <div>
                    <div class="fs-5 fw-bold text-dark">0</div>
                    <div class="text-muted small">Hata</div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--end::Stats Row-->

<!--begin::Welcome Card-->
<div class="card mb-4">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark">Artroplus Kurulumu Tamamlandı</span>
        </h3>
    </div>
    <div class="card-body">
        <div class="alert alert-primary border-0" role="alert">
            <div class="d-flex align-items-start gap-3">
                <i class="bi bi-rocket-takeoff-fill fs-4 mt-1"></i>
                <div>
                    <h6 class="mb-1 fw-bold">Proje başarıyla yapılandırıldı!</h6>
                    <p class="mb-2">5 katmanlı ASP.NET Core mimarisi kurulumu tamamlandı ve Metronic teması aktif.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!--end::Welcome Card-->

<!--begin::Guncelleme Notlari Card-->
<div class="card">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold text-dark">Son Güncelleme Notları</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Sistemdeki son değişiklikler ve yenilikler</span>
        </h3>
        <div class="card-toolbar">
            <button type="button" class="btn btn-sm btn-light-primary" data-bs-toggle="modal" data-bs-target="#kt_modal_guncelleme_notlari">
                <i class="ki-duotone ki-information-5 fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                Tümünü Gör
            </button>
        </div>
    </div>
    <div class="card-body pt-5">
        @if (Model != null && Model.Any())
        {
            <div class="timeline">
                @foreach (var not in Model.Take(3))
                {
                    <div class="timeline-item">
                        <div class="timeline-line w-40px"></div>
                        <div class="timeline-icon symbol symbol-circle symbol-40px me-4">
                            <div class="symbol-label bg-light">
                                @if (not.Tip == "Yeni")
                                {
                                    <i class="ki-duotone ki-star fs-2 text-success"><span class="path1"></span><span class="path2"></span></i>
                                }
                                else if (not.Tip == "Duzeltme")
                                {
                                    <i class="ki-duotone ki-wrench fs-2 text-warning"><span class="path1"></span><span class="path2"></span></i>
                                }
                                else
                                {
                                    <i class="ki-duotone ki-abstract-26 fs-2 text-primary"><span class="path1"></span><span class="path2"></span></i>
                                }
                            </div>
                        </div>
                        <div class="timeline-content mb-10 mt-n1">
                            <div class="pe-3 mb-5">
                                <div class="fs-5 fw-semibold mb-2">@not.Baslik <span class="badge badge-light-primary ms-2">@not.Versiyon</span></div>
                                <div class="d-flex align-items-center mt-1 fs-6">
                                    <div class="text-muted me-2 fs-7">Tarih: @not.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                            </div>
                            <div class="overflow-auto pb-5">
                                <div class="d-flex align-items-center border border-dashed border-gray-300 rounded min-w-700px p-5">
                                    <div class="fs-6 fw-semibold text-gray-700">@not.Icerik</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-10">
                <i class="ki-duotone ki-document fs-3x text-muted mb-3"><span class="path1"></span><span class="path2"></span></i>
                <div class="fs-5 fw-semibold text-muted">Henüz bir güncelleme notu bulunmuyor.</div>
            </div>
        }
    </div>
</div>
<!--end::Guncelleme Notlari Card-->

<!--begin::Modal - Güncelleme Notları-->
<div class="modal fade" id="kt_modal_guncelleme_notlari" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered mw-650px">
        <div class="modal-content rounded">
            <div class="modal-header pb-0 border-0 justify-content-end">
                <div class="btn btn-sm btn-icon btn-active-color-primary" data-bs-dismiss="modal">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
            </div>
            <div class="modal-body scroll-y px-10 px-lg-15 pt-0 pb-15">
                <div class="mb-13 text-center">
                    <h1 class="mb-3">Sistem Güncelleme Notları</h1>
                    <div class="text-muted fw-semibold fs-5">Sistemdeki son değişiklikler ve versiyon geçmişi</div>
                </div>
                
                @if (Model != null && Model.Any())
                {
                    <div class="timeline">
                        @foreach (var not in Model)
                        {
                            <div class="timeline-item">
                                <div class="timeline-line w-40px"></div>
                                <div class="timeline-icon symbol symbol-circle symbol-40px">
                                    <div class="symbol-label bg-light">
                                        @if (not.Tip == "Yeni")
                                        {
                                            <i class="ki-duotone ki-star fs-2 text-success"><span class="path1"></span><span class="path2"></span></i>
                                        }
                                        else if (not.Tip == "Duzeltme")
                                        {
                                            <i class="ki-duotone ki-wrench fs-2 text-warning"><span class="path1"></span><span class="path2"></span></i>
                                        }
                                        else
                                        {
                                            <i class="ki-duotone ki-abstract-26 fs-2 text-primary"><span class="path1"></span><span class="path2"></span></i>
                                        }
                                    </div>
                                </div>
                                <div class="timeline-content mb-10 mt-n1">
                                    <div class="pe-3 mb-5">
                                        <div class="fs-5 fw-semibold mb-2">@not.Baslik <span class="badge badge-light-primary ms-2">@not.Versiyon</span></div>
                                        <div class="text-muted me-2 fs-7">@not.OlusturulmaTarihi.ToString("dd MMMM yyyy, HH:mm")</div>
                                    </div>
                                    <div class="overflow-auto pb-5">
                                        <div class="d-flex align-items-center border border-dashed border-gray-300 rounded min-w-700px p-5">
                                            <div class="fs-6 fw-semibold text-gray-700">@not.Icerik</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-10">
                        <div class="fs-5 fw-semibold text-muted">Henüz bir güncelleme notu bulunmuyor.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!--end::Modal - Güncelleme Notları-->

@section Scripts {
    <script>
        // Modalın otomatik açılması için (örneğin cookie kontrolü ile yapılabilir)
        // Eğer kullanıcı yeni güncelleme notlarını görmediyse:
        $(document).ready(function() {
            var hasNotes = @((Model != null && Model.Any()).ToString().ToLower());
            if(hasNotes) {
                // Şimdilik sadece örnek amaçlı konsola yazdırıyoruz.
                console.log("Güncelleme notları yüklendi.");
            }
        });
    </script>
}
